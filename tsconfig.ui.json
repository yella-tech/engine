{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["src/ui/**/*", "src/types.ts", "src/server/routes.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/ui/vite.config.ts"]
}
