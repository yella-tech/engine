{
  "name": "@yella/engine",
  "version": "0.13.1",
  "description": "Durable TypeScript runtime for agents and automations. Effects store their results, retries pick up where you left off.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/server/public dist/server/public",
    "test": "vitest run",
    "test:watch": "vitest --ui --coverage",
    "example": "tsx examples/example.ts",
    "load-test": "tsx examples/load-test.ts",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "background-jobs",
    "durable-execution",
    "typescript",
    "sqlite",
    "workflow",
    "side-effects"
  ],
  "author": "jorgt",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yella-tech/engine.git"
  },
  "homepage": "https://yella.tech",
  "bugs": {
    "url": "https://github.com/yella-tech/engine/issues"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.12.5"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  }
}
